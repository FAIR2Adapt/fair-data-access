        {
          "action": "attribute",
          "target": "https://fair2adapt.eu/"
        }
      ]
    }
  ],
  "prohibition": [
    {
      "target": "https://fair2adapt.eu/data/hamburg-buildings",
      "action": "http://www.w3.org/ns/odrl/2/commercialize"
    }
  ]
}
